{
  "name": "neuk-bike",
  "version": "0.1.0",
  "private": true,
  "description": "Static mobile-friendly map for finding nearby cycle parking across the UK, Ireland and Spain.",
  "keywords": [
    "active-travel",
    "cycle-parking",
    "cycling",
    "edinburgh",
    "england",
    "ireland",
    "scotland",
    "spain",
    "wales",
    "map",
    "nextjs"
  ],
  "homepage": "https://neuk.bike",
  "bugs": {
    "url": "https://github.com/taugr/neuk-bike/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/neuk-bike.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy:cloudflare": "pnpm build && wrangler pages deploy out --project-name neuk-bike --branch main",
    "start": "next start",
    "update:data": "node scripts/update-cycle-parking-data.mjs",
    "verify:data": "node scripts/verify-cycle-parking-data.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "posthog-js": "^1.402.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "osm-pbf-parser-node": "1.1.4",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10",
    "wrangler": "4.112.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
