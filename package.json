{
  "name": "neuk-bike",
  "version": "0.1.0",
  "private": true,
  "description": "Static mobile-friendly map for finding nearby Edinburgh cycle parking.",
  "keywords": [
    "active-travel",
    "cycle-parking",
    "cycling",
    "edinburgh",
    "map",
    "nextjs"
  ],
  "homepage": "https://neuk.bike",
  "bugs": {
    "url": "https://github.com/taugr/neuk-bike/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/neuk-bike.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/generate-parking-share-pages.mjs",
    "start": "next start",
    "update:data": "node scripts/update-cycle-parking-data.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.40.0",
    "next": "^16.2.7",
    "posthog-js": "^1.379.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
