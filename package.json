{
  "name": "neuk-bike",
  "version": "0.1.0",
  "private": true,
  "description": "Static mobile-friendly map for finding nearby Edinburgh cycle parking.",
  "keywords": [
    "active-travel",
    "cycle-parking",
    "cycling",
    "edinburgh",
    "map",
    "nextjs"
  ],
  "homepage": "https://neuk.bike",
  "bugs": {
    "url": "https://github.com/taugr/neuk-bike/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/neuk-bike.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/generate-parking-share-pages.mjs",
    "start": "next start",
    "update:data": "node scripts/update-cycle-parking-data.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "posthog-js": "^1.386.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
