{
  // Enable Renovate
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',

  // Extend from recommended base configuration
  extends: ['config:recommended', ':disableDependencyDashboard'],

  // Timezone for schedules
  timezone: 'Asia/Yerevan',

  // Fallback schedule for anything without a specific schedule
  schedule: ['* 0-12 * * 1-5'],

  // Labels for GitHub PRs
  labels: ['dependencies'],

  // Package rules for different update schedules
  packageRules: [
    {
      description: 'Wait one day before updating npm packages',
      matchDatasources: ['npm'],
      minimumReleaseAge: '1 day',
      internalChecksFilter: 'strict',
    },
    {
      description: 'Review lockfile maintenance with pnpm release-age enforcement',
      matchUpdateTypes: ['lockFileMaintenance'],
    },
    {
      description: 'Review package replacement updates with pnpm release-age enforcement',
      matchUpdateTypes: ['replacement'],
    },
    {
      description: 'Review package pinning updates with pnpm release-age enforcement',
      matchUpdateTypes: ['pin'],
    },
    {
      description: 'Update dependencies every weekday morning',
      matchDepTypes: [
        'dependencies',
        'peerDependencies',
        'pnpm.catalog',
        'pnpm.catalog.*',
      ],
      // Cron: Weekdays in the morning (minute hour day month weekday)
      schedule: ['* 0-12 * * 1-5'],
    },
    {
      description: 'Update devDependencies every Saturday morning',
      matchDepTypes: ['devDependencies'],
      // Cron: Every Saturday in the morning (minute hour day month weekday)
      schedule: ['* 0-12 * * 6'],
    },
    {
      description: 'Update pnpm every Saturday morning',
      matchDepNames: ['pnpm'],
      // Cron: Every Saturday in the morning (minute hour day month weekday)
      schedule: ['* 0-12 * * 6'],
    },
    {
      description: 'Update GitHub Actions workflows on 3rd Monday of the month',
      matchFileNames: ['.github/workflows/**'],
      // Cron: Every Monday during days 15-21 (contains 3rd Monday)
      schedule: ['* * 15-21 * 1'],
    },
    {
      description: 'Group and automerge non-major devDependencies updates; majors stay one PR per package',
      matchDepTypes: ['devDependencies'],
      matchUpdateTypes: ['minor', 'patch'],
      groupName: 'dev dependencies',
      automerge: true,
      automergeType: 'pr',
    },
    {
      description: 'Automerge non-major pnpm updates like devDependencies',
      matchDepNames: ['pnpm'],
      matchUpdateTypes: ['minor', 'patch'],
      automerge: true,
      automergeType: 'pr',
    },
  ],
}
